# Copy to .env.local for development, or .env for production.
# All values here are examples — replace before use.

# ─────────────────────────────────────────────────────────────
# Database
# SQLite by default. To switch to Postgres, change to something like:
#   DATABASE_URL="postgresql://user:pass@host:5432/zagagsheli"
# then run: npx prisma migrate deploy
# ─────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# ─────────────────────────────────────────────────────────────
# Auth.js (NextAuth v5)
# Generate: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# ─────────────────────────────────────────────────────────────
# Seeded admin user (used by prisma/seed.ts only)
# ─────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@zagagsheli.co.il"
ADMIN_PASSWORD="Admin1234!"
ADMIN_NAME="Lior Filiba"

# ─────────────────────────────────────────────────────────────
# Leads-inbox JSON API key (read-only external access)
# Callers pass this in the `x-api-key` header.
# ─────────────────────────────────────────────────────────────
LEADS_API_KEY="change-me-generate-with-openssl-rand-hex-32"

# ─────────────────────────────────────────────────────────────
# Lead notification email (owner receives a copy of every new lead)
# Provider abstraction — set SMTP_* to activate; otherwise notifications
# are logged to server console only.
# ─────────────────────────────────────────────────────────────
LEAD_NOTIFY_EMAIL="lior@zagagsheli.co.il"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="הזגג שלי <no-reply@zagagsheli.co.il>"

# ─────────────────────────────────────────────────────────────
# Analytics (managed from admin Settings; env vars are fallbacks)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_GA4_ID=""
